# 内容：需要代理的网址
#
# 域名关键字匹配
# DOMAIN-KEYWORD,xxxx
#
# 域名后缀匹配
# DOMAIN-SUFFIX,xxxx.xxx

DOMAIN-SUFFIX,suno.com
DOMAIN-KEYWORD,suno
DOMAIN-SUFFIX,tdacestudio.com

# Google DL
DOMAIN-SUFFIX,dl.google.com
DOMAIN-SUFFIX,dl.l.google.com

# AWS us-west 区域统一走代理，覆盖区域下载与对象存储域名
DOMAIN-SUFFIX,us-west-1.amazonaws.com
DOMAIN-SUFFIX,us-west-2.amazonaws.com
# DOMAIN-SUFFIX,cloudinary.com

DOMAIN-SUFFIX,archive.org
